{
    "compilerOptions": {
      "outDir": "./dist/",
      "noImplicitAny": true,
      "module": "es6",
      "target": "es5",
      "jsx": "react",
      "allowJs": true,
      "moduleResolution": "node",
      "sourceMap": true,
      "allowSyntheticDefaultImports": true,
      "paths": {
        "@Widgets/*": ["./src/Components/Widgets/*"],
        "@UI/*": ["./src/Components/UI/*"],
        "@Lib/*": ["./src/Lib/*"],
        "@Utils": ["./src/Lib/utils.tsx"],
      }
    },
    "include": ["src/**/*"]
  }